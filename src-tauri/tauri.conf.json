{
  "productName": "OneMark",
  "version": "0.0.2",
  "identifier": "com.monto.markdown",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "OneMark - Markdown Editor",
        "width": 1024,
        "height": 768,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "decorations": true,
        "transparent": false,
        "shadow": true,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"],
    "macOS": {
      "infoPlist": "Info.plist"
    },
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/32x32.png"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "name": "Markdown 文档",
        "description": "Markdown 文本文件",
        "mimeType": "text/markdown",
        "role": "Editor",
        "rank": "Default",
        "contentTypes": ["net.daringfireball.markdown", "public.plain-text"]
      },
      {
        "ext": ["txt"],
        "name": "纯文本",
        "description": "纯文本文件",
        "mimeType": "text/plain",
        "role": "Editor",
        "rank": "Alternate",
        "contentTypes": ["public.plain-text", "public.text"]
      }
    ]
  }
}
