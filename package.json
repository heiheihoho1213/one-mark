{
  "name": "OneMark",
  "private": true,
  "version": "0.0.2",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:mac-arm": "tauri build --target aarch64-apple-darwin",
    "tauri:build:mac-intel": "tauri build --target x86_64-apple-darwin",
    "tauri:build:mac-universal": "tauri build --target universal-apple-darwin",
    "tauri:build:win": "tauri build --target x86_64-pc-windows-msvc",
    "tauri:check:win": "cargo check --manifest-path src-tauri/Cargo.toml --target x86_64-pc-windows-msvc",
    "tauri:targets:install": "rustup target add aarch64-apple-darwin x86_64-apple-darwin x86_64-pc-windows-msvc",
    "tauri:clean": "rm -rf src-tauri/target src-tauri/.tauri",
    "tauri": "tauri",
    "release": "node scripts/release-tag.mjs",
    "release:retag": "node scripts/release-retag.mjs"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.546.0",
    "marked": "^18.0.5",
    "mermaid": "^11.15.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
